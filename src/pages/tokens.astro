---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getMergedProjects } from '../lib/merge.js';
import { getClaudeUsage } from '../lib/claudeUsage.js';
import type { MergedProject } from '../types/project.js';
import type { ProjectUsage } from '../lib/claudeUsage.js';

let projects: MergedProject[] = [];
let usageMap = new Map<string, ProjectUsage>();
let loadError = false;

try {
  projects = await getMergedProjects();
  usageMap = await getClaudeUsage(projects);
} catch (err) {
  console.error('[tokens] load failed:', err);
  loadError = true;
}

function fmt(n: number) {
  return n.toLocaleString();
}

function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const rows = projects
  .map((p) => ({ project: p, usage: usageMap.get(p.id) ?? null }))
  .sort((a, b) => {
    const aHasUsage = a.usage && a.usage.sessionCount > 0;
    const bHasUsage = b.usage && b.usage.sessionCount > 0;
    if (aHasUsage && !bHasUsage) return -1;
    if (!aHasUsage && bHasUsage) return 1;
    const aTotal = (a.usage?.inputTokens ?? 0) + (a.usage?.outputTokens ?? 0);
    const bTotal = (b.usage?.inputTokens ?? 0) + (b.usage?.outputTokens ?? 0);
    return bTotal - aTotal;
  });

const rowsWithUsage = rows.filter((r) => r.usage && r.usage.sessionCount > 0);
const grandInput = rowsWithUsage.reduce((s, r) => s + r.usage!.inputTokens, 0);
const grandOutput = rowsWithUsage.reduce((s, r) => s + r.usage!.outputTokens, 0);
const grandCache = rowsWithUsage.reduce((s, r) => s + r.usage!.cacheCreationTokens + r.usage!.cacheReadTokens, 0);
const grandSessions = rowsWithUsage.reduce((s, r) => s + r.usage!.sessionCount, 0);
const grandTotal = grandInput + grandOutput;

function pct(usage: ProjectUsage): string {
  if (grandTotal === 0) return '0%';
  return ((usage.inputTokens + usage.outputTokens) / grandTotal * 100).toFixed(1) + '%';
}

function pctNum(usage: ProjectUsage): number {
  if (grandTotal === 0) return 0;
  return (usage.inputTokens + usage.outputTokens) / grandTotal * 100;
}
---

<BaseLayout title="Token Usage — Project Dashboard">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <header class="mb-8">
      <div class="flex items-center justify-between mb-1">
        <h1 class="font-display text-2xl font-bold text-slate-900 dark:text-slate-100">Token Usage</h1>
        <nav aria-label="Site navigation" class="flex items-center gap-4">
          <a href="/" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Dashboard</a>
          <a href="/momentum" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Momentum</a>
          <a href="/recent" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Recent</a>
          <a href="/notes" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Notes</a>
        </nav>
      </div>
      <p class="text-sm text-slate-500 dark:text-slate-500">Claude Code session token totals, read from <code class="font-mono text-xs bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-1 py-0.5 rounded">~/.claude/projects/</code>. Refreshes on every page load.</p>
    </header>

    {loadError && (
      <div class="bg-red-100 dark:bg-red-950/50 text-red-800 dark:text-red-300 p-4 mb-6 rounded-lg text-sm">
        Failed to load project or token data.
      </div>
    )}

    {projects.length === 0 && !loadError && (
      <p class="text-slate-500 dark:text-slate-500 text-sm">No projects found.</p>
    )}

    {projects.length > 0 && (
      <div class="bg-slate-50 dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-slate-950/60">
              <th class="text-left px-4 py-3 font-semibold text-slate-600 dark:text-slate-400">Project</th>
              <th class="text-right px-4 py-3 font-semibold text-slate-600 dark:text-slate-400">Sessions</th>
              <th class="text-right px-4 py-3 font-semibold text-slate-600 dark:text-slate-400">Input</th>
              <th class="text-right px-4 py-3 font-semibold text-slate-600 dark:text-slate-400">Output</th>
              <th class="text-right px-4 py-3 font-semibold text-slate-600 dark:text-slate-400">Cache</th>
              <th class="text-right px-4 py-3 font-semibold text-slate-600 dark:text-slate-400">Share</th>
              <th class="text-right px-4 py-3 font-semibold text-slate-600 dark:text-slate-400">Last Session</th>
            </tr>
          </thead>
          <tbody>
            {rows.map(({ project, usage }) => (
              <tr class={`border-b ${usage ? 'border-slate-100 dark:border-slate-800 hover:bg-slate-100 dark:hover:bg-slate-800/60' : 'border-slate-100 dark:border-slate-800/50'} transition-colors ${!usage ? 'opacity-60' : ''}`}>
                <td class="px-4 py-3 font-medium text-slate-900 dark:text-slate-200">{project.name}</td>
                <td class="px-4 py-3 text-right text-slate-600 dark:text-slate-400 tabular-nums">{usage?.sessionCount ?? '—'}</td>
                <td class="px-4 py-3 text-right text-slate-700 dark:text-slate-300 tabular-nums">{usage ? fmt(usage.inputTokens) : '—'}</td>
                <td class="px-4 py-3 text-right text-slate-700 dark:text-slate-300 tabular-nums">{usage ? fmt(usage.outputTokens) : '—'}</td>
                <td class="px-4 py-3 text-right text-slate-500 dark:text-slate-500 tabular-nums">{usage ? fmt(usage.cacheCreationTokens + usage.cacheReadTokens) : '—'}</td>
                <td class="px-4 py-3 text-right">
                  {usage ? (
                    <div class="flex flex-col items-end gap-1">
                      <span class="text-indigo-600 dark:text-indigo-400 font-semibold tabular-nums text-xs">{pct(usage)}</span>
                      <div class="w-16 h-1.5 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
                        <div class="h-full bg-indigo-400 dark:bg-indigo-500 rounded-full" style={`width: ${pctNum(usage).toFixed(1)}%`}></div>
                      </div>
                    </div>
                  ) : (
                    <span class="text-slate-400 dark:text-slate-500">—</span>
                  )}
                </td>
                <td class="px-4 py-3 text-right text-slate-500 dark:text-slate-500">{usage ? fmtDate(usage.lastSessionDate) : '—'}</td>
              </tr>
            ))}
          </tbody>
          {rowsWithUsage.length > 0 && (
            <tfoot>
              <tr class="bg-slate-100 dark:bg-slate-950/60 border-t border-slate-200 dark:border-slate-800 font-semibold">
                <td class="px-4 py-3 text-slate-700 dark:text-slate-300">Total</td>
                <td class="px-4 py-3 text-right text-slate-700 dark:text-slate-300 tabular-nums">{grandSessions}</td>
                <td class="px-4 py-3 text-right text-slate-700 dark:text-slate-300 tabular-nums">{fmt(grandInput)}</td>
                <td class="px-4 py-3 text-right text-slate-700 dark:text-slate-300 tabular-nums">{fmt(grandOutput)}</td>
                <td class="px-4 py-3 text-right text-slate-700 dark:text-slate-300 tabular-nums">{fmt(grandCache)}</td>
                <td class="px-4 py-3 text-right text-indigo-600 dark:text-indigo-400 font-semibold text-xs">100%</td>
                <td class="px-4 py-3"></td>
              </tr>
            </tfoot>
          )}
        </table>
      </div>
    )}
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getMergedProjects } from '../lib/merge.js';
import { getRecentLogs, relativeTime, fmtTokens } from '../lib/recentLogs.js';
import type { SessionEntry } from '../lib/recentLogs.js';
import type { MergedProject } from '../types/project.js';

let allProjects: MergedProject[] = [];
let loadError = false;
let globalFeed: SessionEntry[] = [];
let byProject = new Map<string, SessionEntry>();

try {
  allProjects = await getMergedProjects();
  ({ globalFeed, byProject } = await getRecentLogs(allProjects, { limit: 7 }));
} catch (err) {
  console.error('[recent] failed:', err);
  loadError = true;
}

// Per-project list: all tracked projects, showing most recent session if available.
const projectSessions = allProjects
  .map((p) => ({ project: p, session: byProject.get(p.id) ?? null }))
  .sort((a, b) => (b.session?.mtime ?? 0) - (a.session?.mtime ?? 0));

// Sessions from dirs not matched to any tracked project (home dir work, etc.)
const unmatchedSessions = [...byProject.values()]
  .filter((s) => s.projectId === null)
  .sort((a, b) => b.mtime - a.mtime);
---

<BaseLayout title="Recent Work — Project Dashboard">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <header class="mb-8">
      <div class="flex items-center justify-between mb-1">
        <h1 class="font-display text-2xl font-bold text-slate-900 dark:text-slate-100">Recent Work</h1>
        <nav aria-label="Site navigation" class="flex items-center gap-4">
          <a href="/" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Dashboard</a>
          <a href="/momentum" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Momentum</a>
          <a href="/notes" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Notes</a>
          <a href="/tokens" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Tokens</a>
        </nav>
      </div>
      <p class="text-sm text-slate-500 dark:text-slate-500">Most recent Claude Code sessions by project — filtered to substantive work (≥20k output tokens). Refreshes on load.</p>
    </header>

    {loadError && (
      <div class="bg-red-100 dark:bg-red-950/50 text-red-800 dark:text-red-300 p-4 mb-6 rounded">
        Failed to load session logs.
      </div>
    )}

    <!-- Global recent feed -->
    <section class="mb-10" aria-labelledby="global-heading">
      <h2 id="global-heading" class="font-display text-xs font-semibold text-slate-500 dark:text-slate-500 mb-3 uppercase tracking-wide">
        Most recent sessions — across all projects
      </h2>

      {globalFeed.length === 0 ? (
        <p class="text-sm text-slate-400 dark:text-slate-600 italic">No major sessions found.</p>
      ) : (
        <div class="flex flex-col gap-2">
          {globalFeed.map((s) => (
            <div class="flex items-start gap-3 rounded-lg px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-slate-900 dark:text-slate-100 leading-snug">{s.title}</p>
                {s.description && (
                  <p class="text-xs text-slate-600 dark:text-slate-400 mt-0.5 leading-snug line-clamp-2">{s.description}</p>
                )}
                <p class="text-xs text-slate-400 dark:text-slate-500 mt-1">
                  {s.projectName ?? <span class="italic">general</span>}
                </p>
              </div>
              <div class="flex items-center gap-2 shrink-0 mt-0.5">
                <span class="text-xs text-slate-400 dark:text-slate-500 tabular-nums whitespace-nowrap">{relativeTime(s.mtime)}</span>
                <span class="text-xs font-mono bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 px-1.5 py-0.5 rounded" title={`${s.outputTokens.toLocaleString()} output tokens`}>
                  {fmtTokens(s.outputTokens)}
                </span>
              </div>
            </div>
          ))}
        </div>
      )}
    </section>

    <!-- Per-project most recent session -->
    <section aria-labelledby="by-project-heading">
      <h2 id="by-project-heading" class="font-display text-xs font-semibold text-slate-500 dark:text-slate-500 mb-3 uppercase tracking-wide">
        Last major session per project
      </h2>

      {projectSessions.length === 0 && unmatchedSessions.length === 0 ? (
        <p class="text-sm text-slate-400 dark:text-slate-600 italic">No sessions found.</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {projectSessions.map(({ project, session }) => (
            session ? (
              <div class="rounded-lg px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 border-l-4 border-l-indigo-400 dark:border-l-indigo-600">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 truncate">{project.name}</span>
                  <span class="text-xs text-slate-400 dark:text-slate-500 tabular-nums ml-2 shrink-0">{relativeTime(session.mtime)}</span>
                </div>
                <p class="text-sm font-medium text-slate-800 dark:text-slate-200 leading-snug">{session.title}</p>
                {session.description && (
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 leading-snug line-clamp-2">{session.description}</p>
                )}
              </div>
            ) : (
              <div class="rounded-lg px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 border-l-4 border-l-slate-300 dark:border-l-slate-700">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs font-semibold text-slate-600 dark:text-slate-400 truncate">{project.name}</span>
                </div>
                <p class="text-sm text-slate-500 dark:text-slate-500 italic">No sessions yet</p>
              </div>
            )
          ))}

          {unmatchedSessions.length > 0 && (
            <div class="rounded-lg px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 border-l-4 border-l-slate-300 dark:border-l-slate-600">
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-semibold text-slate-400 dark:text-slate-500 italic">general (no project)</span>
                <span class="text-xs text-slate-400 dark:text-slate-500 tabular-nums ml-2 shrink-0">{relativeTime(unmatchedSessions[0].mtime)}</span>
              </div>
              <p class="text-sm font-medium text-slate-800 dark:text-slate-200 leading-snug">{unmatchedSessions[0].title}</p>
              {unmatchedSessions[0].description && (
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 leading-snug line-clamp-2">{unmatchedSessions[0].description}</p>
              )}
            </div>
          )}
        </div>
      )}
    </section>
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getMergedProjects } from '../lib/merge.js';
import { readManual } from '../lib/manual.js';
import { getRecommendation } from '../lib/recommend.js';
import ProjectCard from '../components/ProjectCard.astro';
import WeeklyDigest from '../components/WeeklyDigest.astro';
import NextUp from '../components/NextUp.astro';
import type { MergedProject } from '../types/project.js';

let allProjects: MergedProject[] = [];
let loadError = false;
try {
  const manual = readManual();
  allProjects = await getMergedProjects(manual);
} catch (err) {
  console.error('[dashboard] getMergedProjects() failed:', err);
  loadError = true;
}

const BOARD_STATUSES = ['active', 'in-progress', 'on-hold'] as const;
const COLLAPSED_STATUSES = new Set(['complete', 'archived']);

const buckets: Record<typeof BOARD_STATUSES[number], MergedProject[]> = {
  active: [],
  'in-progress': [],
  'on-hold': [],
};

const completedProjects: MergedProject[] = [];

for (const project of allProjects) {
  if (COLLAPSED_STATUSES.has(project.status)) {
    completedProjects.push(project);
    continue;
  }
  const s = project.status as typeof BOARD_STATUSES[number];
  if (s in buckets) {
    buckets[s].push(project);
  }
}

const sectionLabels: Record<typeof BOARD_STATUSES[number], string> = {
  active: 'Active',
  'in-progress': 'In Progress',
  'on-hold': 'On Hold',
};

const todayStr = new Date().toISOString().slice(0, 10);
const recommendation = getRecommendation(allProjects, todayStr);
---

<BaseLayout title="Project Dashboard">
    <div class="max-w-5xl mx-auto px-4 py-8">
      <header class="mb-8">
        <div class="flex items-center justify-between">
          <h1 class="font-display text-2xl font-bold text-slate-900 dark:text-slate-100">Project Dashboard</h1>
          <nav aria-label="Site navigation" class="flex items-center gap-4">
            <a href="/momentum" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Momentum</a>
            <a href="/notes" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Notes</a>
            <a href="/tokens" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Tokens</a>
          </nav>
        </div>
        <p class="text-sm text-slate-500 dark:text-slate-500 mt-1">What am I working on, where does it stand, and what's due when.</p>
      </header>

      {loadError && (
        <div class="bg-red-100 dark:bg-red-950/50 text-red-800 dark:text-red-300 p-4 mb-4 rounded">
          Failed to load projects. Check OS_PROJECTS_DIR and data/manual.json.
        </div>
      )}

      <NextUp project={recommendation} today={todayStr} />

      <WeeklyDigest projects={allProjects} />

      <div class="border-t border-slate-200 dark:border-slate-800 my-6" role="separator" aria-hidden="true"></div>

      <main class="flex flex-col gap-10 bg-slate-100 dark:bg-slate-900/60 rounded-xl p-6">
        {BOARD_STATUSES.map((status) => {
          const projects = buckets[status];
          return (
            <section aria-labelledby={`section-${status}`}>
              <div class="flex items-center gap-3 mb-4">
                <h2
                  id={`section-${status}`}
                  class="font-display text-lg font-bold text-slate-800 dark:text-slate-200"
                >
                  {sectionLabels[status]}
                </h2>
                <span class="text-sm text-slate-500 dark:text-slate-500 font-normal">
                  ({projects.length})
                </span>
              </div>

              {projects.length === 0 ? (
                <p class="text-sm text-slate-400 dark:text-slate-600 italic">No projects.</p>
              ) : (
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                  {projects.map((project) => (
                    <ProjectCard project={project} />
                  ))}
                </div>
              )}
            </section>
          );
        })}
      </main>

      {completedProjects.length > 0 && (
        <details class="mt-10">
          <summary class="cursor-pointer text-sm font-medium text-slate-500 dark:text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 transition-colors duration-150 select-none">
            Completed ({completedProjects.length})
          </summary>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 mt-4">
            {completedProjects.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        </details>
      )}

    </div>
</BaseLayout>

---
import '../styles/global.css';
import { getMergedProjects } from '../lib/merge.js';
import { readManual } from '../lib/manual.js';
import { getRecommendation } from '../lib/recommend.js';
import ProjectCard from '../components/ProjectCard.astro';
import WeeklyDigest from '../components/WeeklyDigest.astro';
import NextUp from '../components/NextUp.astro';
import TokenTracker from '../components/TokenTracker.astro';
import type { MergedProject } from '../types/project.js';
import type { TokenLogEntry } from '../types/manual.js';

let allProjects: MergedProject[] = [];
let tokenLog: TokenLogEntry[] = [];
let loadError = false;
try {
  const manual = readManual();
  tokenLog = manual.token_log;
  allProjects = await getMergedProjects(manual);
} catch (err) {
  console.error('[dashboard] getMergedProjects() failed:', err);
  loadError = true;
}

const BOARD_STATUSES = ['active', 'in-progress', 'on-hold'] as const;
const COLLAPSED_STATUSES = new Set(['complete', 'archived']);

const buckets: Record<typeof BOARD_STATUSES[number], MergedProject[]> = {
  active: [],
  'in-progress': [],
  'on-hold': [],
};

const completedProjects: MergedProject[] = [];

for (const project of allProjects) {
  if (COLLAPSED_STATUSES.has(project.status)) {
    completedProjects.push(project);
    continue;
  }
  const s = project.status as typeof BOARD_STATUSES[number];
  if (s in buckets) {
    buckets[s].push(project);
  }
}

const sectionLabels: Record<typeof BOARD_STATUSES[number], string> = {
  active: 'Active',
  'in-progress': 'In Progress',
  'on-hold': 'On Hold',
};

const todayStr = new Date().toISOString().slice(0, 10);
const recommendation = getRecommendation(allProjects, todayStr);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Project Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans bg-slate-50 min-h-screen text-slate-900">
    <div class="max-w-5xl mx-auto px-4 py-8">
      <header class="mb-8">
        <div class="flex items-center justify-between">
          <h1 class="font-display text-2xl font-bold text-slate-900">Project Dashboard</h1>
          <nav aria-label="Site navigation" class="flex items-center gap-4">
            <a href="/momentum" class="text-sm text-slate-500 hover:text-slate-700 transition-colors duration-150">Momentum</a>
            <a href="/notes" class="text-sm text-slate-500 hover:text-slate-700 transition-colors duration-150">Notes</a>
          </nav>
        </div>
        <p class="text-sm text-slate-500 mt-1">What am I working on, where does it stand, and what's due when.</p>
      </header>

      {loadError && (
        <div class="bg-red-100 text-red-800 p-4 mb-4 rounded">
          Failed to load projects. Check OS_PROJECTS_DIR and data/manual.json.
        </div>
      )}

      <NextUp project={recommendation} today={todayStr} />

      <WeeklyDigest projects={allProjects} />

      <div class="border-t border-slate-200 my-6" role="separator" aria-hidden="true"></div>

      <main class="flex flex-col gap-10 bg-slate-100 rounded-xl p-6">
        {BOARD_STATUSES.map((status) => {
          const projects = buckets[status];
          return (
            <section aria-labelledby={`section-${status}`}>
              <div class="flex items-center gap-3 mb-4">
                <h2
                  id={`section-${status}`}
                  class="font-display text-lg font-bold text-slate-800"
                >
                  {sectionLabels[status]}
                </h2>
                <span class="text-sm text-slate-500 font-normal">
                  ({projects.length})
                </span>
              </div>

              {projects.length === 0 ? (
                <p class="text-sm text-slate-400 italic">No projects.</p>
              ) : (
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                  {projects.map((project) => (
                    <ProjectCard project={project} />
                  ))}
                </div>
              )}
            </section>
          );
        })}
      </main>

      {completedProjects.length > 0 && (
        <details class="mt-10">
          <summary class="cursor-pointer text-sm font-medium text-slate-500 hover:text-slate-700 transition-colors duration-150 select-none">
            Completed ({completedProjects.length})
          </summary>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 mt-4">
            {completedProjects.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        </details>
      )}

      <TokenTracker projects={allProjects} tokenLog={tokenLog} />

    </div>
  </body>
</html>

---
import '../styles/global.css';
import { getMergedProjects } from '../lib/merge.js';
import { getCommitDates } from '../lib/git.js';
import MomentumView from '../components/MomentumView.astro';
import type { MergedProject } from '../types/project.js';

const VALID_SCOPES = ['7', '30', '90'] as const;
type Scope = typeof VALID_SCOPES[number];

const rawScope = Astro.url.searchParams.get('scope') ?? '30';
const scope: Scope = (VALID_SCOPES as readonly string[]).includes(rawScope)
  ? (rawScope as Scope)
  : '30';
const sinceDays = parseInt(scope, 10);

let allProjects: MergedProject[] = [];
let loadError = false;
try {
  allProjects = await getMergedProjects();
} catch (err) {
  console.error('[momentum] getMergedProjects() failed:', err);
  loadError = true;
}

const STALE_THRESHOLD_DAYS = 14;

interface MomentumEntry {
  project: MergedProject;
  commitDates: string[];
  commitCount: number;
  stalled: boolean;
}

const momentumData: MomentumEntry[] = allProjects.map((project) => {
  const commitDates = project.repo ? getCommitDates(project.repo, sinceDays) : [];
  return {
    project,
    commitDates,
    commitCount: commitDates.length,
    stalled: project.days_since_active > STALE_THRESHOLD_DAYS,
  };
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Momentum — Project Dashboard</title>
  </head>
  <body class="bg-gray-50 min-h-screen text-gray-900">
    <div class="max-w-5xl mx-auto px-4 py-8">
      <header class="mb-8">
        <div class="flex items-center gap-4 mb-1">
          <h1 class="text-2xl font-bold text-gray-900">Momentum</h1>
          <nav aria-label="Site navigation">
            <a
              href="/"
              class="text-sm text-gray-500 hover:text-gray-700"
            >← Dashboard</a>
          </nav>
        </div>
        <p class="text-sm text-gray-500">Git activity across projects for the selected window.</p>
      </header>

      {loadError && (
        <div class="bg-red-100 text-red-800 p-4 mb-4 rounded">
          Failed to load projects. Check OS_PROJECTS_DIR and data/manual.json.
        </div>
      )}

      <MomentumView
        momentumData={momentumData}
        activeScope={scope}
        sinceDays={sinceDays}
      />
    </div>
  </body>
</html>

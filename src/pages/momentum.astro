---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getMergedProjects } from '../lib/merge.js';
import { getCommitDatesAsync } from '../lib/git.js';
import MomentumView from '../components/MomentumView.astro';
import type { MergedProject } from '../types/project.js';

const VALID_SCOPES = ['7', '30', '90'] as const;
type Scope = typeof VALID_SCOPES[number];

const rawScope = Astro.url.searchParams.get('scope') ?? '7';
const scope: Scope = (VALID_SCOPES as readonly string[]).includes(rawScope)
  ? (rawScope as Scope)
  : '7';
const sinceDays = parseInt(scope, 10);

let allProjects: MergedProject[] = [];
let loadError = false;
try {
  allProjects = await getMergedProjects();
} catch (err) {
  console.error('[momentum] getMergedProjects() failed:', err);
  loadError = true;
}

type MomentumStatus = 'surging' | 'moving' | 'slow' | 'stalled' | 'dormant';

interface MomentumEntry {
  project: MergedProject;
  commitDates: string[];
  commitCount: number;
  momentumStatus: MomentumStatus;
}

function getMomentumStatus(commitCount: number, daysSinceActive: number | null): MomentumStatus {
  if (commitCount >= 5) return 'surging';
  if (commitCount >= 2) return 'moving';
  if (commitCount === 1) return 'slow';
  if ((daysSinceActive ?? Infinity) <= 30) return 'stalled';
  return 'dormant';
}

const momentumData: MomentumEntry[] = await Promise.all(
  allProjects.map(async (project) => {
    const commitDates = project.repo ? await getCommitDatesAsync(project.repo, sinceDays) : [];
    return {
      project,
      commitDates,
      commitCount: commitDates.length,
      momentumStatus: getMomentumStatus(commitDates.length, project.days_since_active ?? null),
    };
  }),
);
---

<BaseLayout title="Momentum — Project Dashboard">
    <div class="max-w-5xl mx-auto px-4 py-8">
      <header class="mb-8">
        <div class="flex items-center justify-between mb-1">
          <h1 class="font-display text-2xl font-bold text-slate-900 dark:text-slate-100">Momentum</h1>
          <nav aria-label="Site navigation" class="flex items-center gap-4">
            <a href="/" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Dashboard</a>
            <a href="/notes" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Notes</a>
            <a href="/tokens" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors duration-150">Tokens</a>
          </nav>
        </div>
        <p class="text-sm text-slate-500 dark:text-slate-500">Git activity across projects for the selected window.</p>
      </header>

      {loadError && (
        <div class="bg-red-100 dark:bg-red-950/50 text-red-800 dark:text-red-300 p-4 mb-4 rounded">
          Failed to load projects. Check OS_PROJECTS_DIR and data/manual.json.
        </div>
      )}

      <MomentumView
        momentumData={momentumData}
        activeScope={scope}
        sinceDays={sinceDays}
      />
    </div>
</BaseLayout>

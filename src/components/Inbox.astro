---
import { readManual } from '../lib/manual.js';
import type { InboxItem } from '../types/manual.js';

let items: InboxItem[] = [];
let loadError: string | null = null;
try {
  const manual = readManual();
  items = manual.inbox.filter((item) => !item.done);
} catch (e) {
  loadError = (e as Error).message;
}

function formatCreated(created: string): string {
  const createdDate = new Date(created);
  const today = new Date();
  const todayStr = today.toISOString().slice(0, 10);
  const createdStr = createdDate.toISOString().slice(0, 10);
  if (createdStr === todayStr) return 'today';
  const diffMs = today.setHours(0, 0, 0, 0) - new Date(createdStr).setHours(0, 0, 0, 0);
  const days = Math.floor(diffMs / 86400000);
  return `${days} day${days === 1 ? '' : 's'} ago`;
}
---

<section
  class="mt-8 rounded-lg border border-gray-200 bg-white p-5 shadow-sm"
  aria-label="Quick-capture inbox"
>
  <h2 class="text-base font-semibold text-gray-800 mb-4">Inbox</h2>

  <!-- Add item form -->
  <form id="inbox-add-form" class="flex items-center gap-2 mb-5" novalidate>
    <label for="inbox-text" class="sr-only">Quick note</label>
    <input
      id="inbox-text"
      name="text"
      type="text"
      placeholder="Quick note..."
      autocomplete="off"
      aria-describedby="inbox-add-error"
      class="flex-1 rounded border border-gray-300 px-3 py-1.5 text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400"
    />
    <button
      type="submit"
      aria-label="Add inbox item"
      class="rounded bg-blue-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-400 disabled:opacity-50"
    >
      Add
    </button>
  </form>
  <p
    id="inbox-add-error"
    class="text-xs text-red-600 hidden -mt-3 mb-3"
    role="alert"
    aria-live="polite"
  ></p>

  <!-- Load error -->
  {loadError && (
    <p class="text-xs text-red-600 mb-3" role="alert">Could not load inbox items.</p>
  )}

  <!-- Item list / empty state -->
  {!loadError && items.length === 0 ? (
    <p class="text-sm text-gray-400 italic">No items.</p>
  ) : !loadError && (
    <ul class="flex flex-col gap-2" aria-label="Inbox items">
      {items.map((item) => (
        <li
          class="flex items-start justify-between gap-3 rounded border border-gray-100 bg-gray-50 px-3 py-2"
          data-inbox-id={item.id}
        >
          <div class="flex flex-col gap-0.5 min-w-0">
            <span class="text-sm text-gray-800 break-words">{item.text}</span>
            <div class="flex items-center gap-2 flex-wrap">
              <span class="text-xs text-gray-400">{formatCreated(item.created)}</span>
              {item.project && (
                <span class="inline-block rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700">
                  {item.project}
                </span>
              )}
            </div>
          </div>
          <button
            type="button"
            data-action="delete-inbox-item"
            aria-label={`Delete inbox item: ${item.text}`}
            class="shrink-0 rounded px-1.5 py-0.5 text-gray-400 hover:bg-red-50 hover:text-red-600 focus:outline-none focus:ring-2 focus:ring-red-400 text-sm leading-none disabled:opacity-50"
          >
            &times;
          </button>
        </li>
      ))}
    </ul>
  )}
</section>

<script>
  async function fetchWithTimeout(url: string, options: RequestInit): Promise<Response> {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 10000);
    try {
      const res = await fetch(url, { ...options, signal: controller.signal });
      return res;
    } catch (e) {
      if ((e as Error).name === 'AbortError') {
        throw new Error('Request timed out');
      }
      throw e;
    } finally {
      clearTimeout(timeoutId);
    }
  }

  // --- Add form ---
  const form = document.getElementById('inbox-add-form') as HTMLFormElement | null;
  const textInput = document.getElementById('inbox-text') as HTMLInputElement | null;
  const addError = document.getElementById('inbox-add-error') as HTMLElement | null;

  function showAddError(msg: string) {
    if (addError) {
      addError.textContent = msg;
      addError.classList.remove('hidden');
    }
  }

  function clearAddError() {
    if (addError) {
      addError.textContent = '';
      addError.classList.add('hidden');
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearAddError();

    const text = textInput?.value?.trim() ?? '';
    if (!text) {
      showAddError('Text is required');
      textInput?.focus();
      return;
    }

    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;
    if (textInput) textInput.disabled = true;

    try {
      const res = await fetchWithTimeout('/api/inbox', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, project: null }),
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({})) as Record<string, unknown>;
        throw new Error((data.error as string) ?? `HTTP ${res.status}`);
      }
      window.location.reload();
    } catch (err) {
      showAddError((err as Error).message);
      if (submitBtn) submitBtn.disabled = false;
      if (textInput) textInput.disabled = false;
    }
  });

  // --- Delete buttons ---
  document.querySelectorAll<HTMLElement>('[data-inbox-id]').forEach((row) => {
    const id = row.dataset.inboxId!;
    const deleteBtn = row.querySelector<HTMLButtonElement>('[data-action="delete-inbox-item"]');

    deleteBtn?.addEventListener('click', async () => {
      deleteBtn.disabled = true;

      try {
        const res = await fetchWithTimeout('/api/inbox', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({})) as Record<string, unknown>;
          throw new Error((data.error as string) ?? `HTTP ${res.status}`);
        }
        window.location.reload();
      } catch (err) {
        console.error('[inbox] delete failed:', (err as Error).message);
        deleteBtn.disabled = false;
      }
    });
  });
</script>

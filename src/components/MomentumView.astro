---
import type { MergedProject } from '../types/project.js';

type MomentumStatus = 'surging' | 'moving' | 'slow' | 'stalled' | 'dormant';

interface MomentumEntry {
  project: MergedProject;
  commitDates: string[];
  commitCount: number;
  momentumStatus: MomentumStatus;
}

const BADGE_CONFIG: Record<MomentumStatus, { label: string; cls: string }> = {
  surging: { label: 'surging',  cls: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300' },
  moving:  { label: 'moving',   cls: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400' },
  slow:    { label: 'slow',     cls: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-400' },
  stalled: { label: 'stalled',  cls: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400' },
  dormant: { label: 'dormant',  cls: 'bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-400' },
};

interface Props {
  momentumData: MomentumEntry[];
  activeScope: '7' | '30' | '90';
  sinceDays: number;
}

const { momentumData, activeScope, sinceDays } = Astro.props;

const SCOPES = [
  { label: '7d', value: '7' },
  { label: '30d', value: '30' },
  { label: '90d', value: '90' },
] as const;

// Build a Set of YYYY-MM-DD strings for each project's commit dates
// so we can quickly check which days in the window have commits.
function buildActiveDaySet(commitDates: string[]): Set<string> {
  const days = new Set<string>();
  for (const iso of commitDates) {
    // Slice the date portion from the ISO string (first 10 chars)
    days.add(iso.slice(0, 10));
  }
  return days;
}

// Build the array of YYYY-MM-DD day labels for the scope window,
// oldest first. Day 0 = today, day (sinceDays-1) = oldest.
function buildDayWindow(sinceDays: number): string[] {
  const days: string[] = [];
  const now = new Date();
  for (let i = sinceDays - 1; i >= 0; i--) {
    const d = new Date(now);
    d.setDate(d.getDate() - i);
    days.push(d.toISOString().slice(0, 10));
  }
  return days;
}

const dayWindow = buildDayWindow(sinceDays);

// Pre-compute active day sets for all projects so buildActiveDaySet is not
// called inside the per-row render loop on every render.
const activeDaySets = new Map<string, Set<string>>(
  momentumData.map(({ project, commitDates }) => [
    project.name,
    buildActiveDaySet(commitDates),
  ]),
);
---

<div>
  <!-- Scope selector -->
  <nav aria-label="Activity scope" class="flex gap-2 mb-6">
    {SCOPES.map(({ label, value }) => (
      <a
        href={`/momentum?scope=${value}`}
        class={[
          'px-3 py-1 rounded text-sm font-medium transition-colors duration-150',
          activeScope === value
            ? 'bg-indigo-600 dark:bg-indigo-700 text-slate-100'
            : 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-700 hover:bg-slate-200 dark:hover:bg-slate-700',
        ].join(' ')}
        aria-current={activeScope === value ? 'page' : undefined}
      >
        {label}
      </a>
    ))}
  </nav>

  <!-- Column headers -->
  <div class="grid grid-cols-[1fr_auto_auto_auto] gap-x-4 items-center mb-2 px-2">
    <span class="text-xs font-semibold uppercase tracking-wide text-slate-400 dark:text-slate-600">Project</span>
    <span class="text-xs font-semibold uppercase tracking-wide text-slate-400 dark:text-slate-600">Activity ({sinceDays}d)</span>
    <span class="text-xs font-semibold uppercase tracking-wide text-slate-400 dark:text-slate-600 text-right">Commits</span>
    <span class="text-xs font-semibold uppercase tracking-wide text-slate-400 dark:text-slate-600 text-right">Status</span>
  </div>

  <!-- Project rows -->
  <div class="flex flex-col divide-y divide-slate-100 dark:divide-slate-800">
    {momentumData.map(({ project, commitCount, momentumStatus }) => {
      const activeDays = activeDaySets.get(project.name) ?? new Set<string>();
      const { label: badgeLabel, cls: badgeClass } = BADGE_CONFIG[momentumStatus];

      return (
        <div class="grid grid-cols-[1fr_auto_auto_auto] gap-x-4 items-center py-3 px-2">
          <!-- Project name + days since active -->
          <div class="min-w-0">
            <p class="font-display text-sm font-medium text-slate-900 dark:text-slate-200 truncate">{project.name}</p>
            <p class="text-xs text-slate-500 dark:text-slate-500 mt-0.5">{project.days_since_active}d since active</p>
          </div>

          <!-- Activity bar -->
          <div class="flex items-center gap-px" aria-label={`${project.name} activity over ${sinceDays} days`}>
            {project.repo ? (
              dayWindow.map((day) => (
                <span
                  class={[
                    'w-2 h-4 rounded-sm',
                    activeDays.has(day) ? 'bg-indigo-500 dark:bg-indigo-600' : 'bg-slate-200 dark:bg-slate-800',
                  ].join(' ')}
                  title={day}
                />
              ))
            ) : (
              <span class="text-xs text-slate-400 dark:text-slate-600 italic whitespace-nowrap">no local repo</span>
            )}
          </div>

          <!-- Commit count -->
          <span class="text-sm font-mono text-slate-700 dark:text-slate-400 text-right tabular-nums">
            {project.repo ? commitCount : '—'}
          </span>

          <!-- Momentum status badge -->
          <span
            class={`inline-block rounded-full px-2 py-0.5 text-xs font-medium ${badgeClass}`}
          >
            {badgeLabel}
          </span>
        </div>
      );
    })}

    {momentumData.length === 0 && (
      <p class="text-sm text-slate-400 dark:text-slate-600 italic py-4">No projects found.</p>
    )}
  </div>
</div>

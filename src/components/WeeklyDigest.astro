---
import type { MergedProject } from '../types/project.js';
import { computeDigestBuckets } from '../lib/digest.js';

interface Props {
  projects: MergedProject[];
}

const { projects } = Astro.props;

const { moved, overdue, comingUp } = computeDigestBuckets(projects);
---

<section class="mb-8 rounded-lg border border-gray-200 bg-white p-5 shadow-sm" aria-label="Weekly digest">
  <h2 class="text-base font-semibold text-gray-800 mb-4">Weekly Digest</h2>

  <div class="flex flex-col gap-5 sm:flex-row sm:gap-8">

    <!-- Moved -->
    <div class="flex-1 min-w-0">
      <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Moved</h3>
      {moved.length === 0 ? (
        <p class="text-sm text-gray-400 italic">Nothing here.</p>
      ) : (
        <ul class="flex flex-col gap-1">
          {moved.map((p) => (
            <li class="text-sm text-gray-800">
              <span class="font-medium">{p.name}</span>
              <span class="text-gray-500"> — active {p.days_since_active} day{p.days_since_active === 1 ? '' : 's'} ago</span>
            </li>
          ))}
        </ul>
      )}
    </div>

    <!-- Overdue -->
    <div class="flex-1 min-w-0">
      <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Overdue</h3>
      {overdue.length === 0 ? (
        <p class="text-sm text-gray-400 italic">Nothing here.</p>
      ) : (
        <ul class="flex flex-col gap-1">
          {overdue.map((p) => (
            <li class="text-sm text-gray-800">
              <span class="font-medium">{p.name}</span>
              <span class="text-red-600"> — due {p.due_date}</span>
            </li>
          ))}
        </ul>
      )}
    </div>

    <!-- Coming up -->
    <div class="flex-1 min-w-0">
      <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Coming up</h3>
      {comingUp.length === 0 ? (
        <p class="text-sm text-gray-400 italic">Nothing here.</p>
      ) : (
        <ul class="flex flex-col gap-1">
          {comingUp.map((p) => (
            <li class="text-sm text-gray-800">
              <span class="font-medium">{p.name}</span>
              <span class="text-gray-500"> — due {p.due_date}</span>
            </li>
          ))}
        </ul>
      )}
    </div>

  </div>
</section>

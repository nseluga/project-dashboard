---
import type { MergedProject } from '../types/project.js';

interface Props {
  project: MergedProject | null;
  today: string;
}

const { project, today } = Astro.props;

const DATE_RE = /^\d{4}-\d{2}-\d{2}$/;
const STALENESS_THRESHOLD_DAYS = 14;

// Build reason tags explaining why this project was chosen
function buildReasonTags(p: MergedProject, today: string): string[] {
  const tags: string[] = [];

  // Due-date urgency tags
  const due = p.due_date && DATE_RE.test(p.due_date) ? p.due_date : null;

  if (due) {
    if (due < today) {
      tags.push('overdue');
    } else {
      const msPerDay = 86_400_000;
      const daysUntil = Math.round((Date.parse(due) - Date.parse(today)) / msPerDay);
      if (daysUntil <= 3) tags.push('due in 3 days');
      else if (daysUntil <= 7) tags.push('due this week');
      else if (daysUntil <= 14) tags.push('due in 2 weeks');
    }
  }

  // Priority tag
  if (p.priority === 'high') tags.push('high priority');
  else if (p.priority === 'medium') tags.push('medium priority');

  // Staleness tag
  if (Number.isFinite(p.days_since_active) && p.days_since_active > STALENESS_THRESHOLD_DAYS) {
    tags.push(`${p.days_since_active} days stale`);
  }

  // Status tag for active projects
  if (p.status === 'active') tags.push('active');

  return tags;
}

const reasonTags = project ? buildReasonTags(project, today) : [];
---

{project && (
  <div class="rounded-lg border border-indigo-200 bg-indigo-50 p-5 shadow-sm mb-6">
    <p class="text-xs font-semibold uppercase tracking-wide text-indigo-400 mb-1">Up next</p>
    <h2 class="font-display text-lg font-bold text-slate-900 mb-1">{project.name}</h2>
    {project.next_step && (
      <p class="text-sm text-slate-700 mb-3">{project.next_step}</p>
    )}
    {reasonTags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {reasonTags.map((tag) => (
          <span class="inline-block rounded-full px-2 py-0.5 text-xs font-medium bg-indigo-100 text-indigo-700">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
)}
